# Spesa Pronta AI Backend
# Copia questo file in .env e inserisci la tua chiave.
# NON mettere mai questa chiave dentro index.html, app.js o frontend pubblico.

OPENAI_API_KEY=INSERISCI_LA_TUA_CHIAVE_OPENAI
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=45000
PORT=3000
DB_PATH=./cloud-db.json

# Database cloud Supabase/Postgres
# Incolla su Render la stringa completa preparata da Supabase.
DATABASE_URL=postgresql://postgres.xxxxx:LA_TUA_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:5432/postgres


# Sicurezza dati / cifratura lato server
# Metti una frase lunga casuale su Render. Non cambiarla dopo che ci sono utenti veri,
# altrimenti il database cifrato non si può più leggere.
APP_SECRET=INSERISCI_UN_SEGRETO_LUNGO_RANDOM
APP_BASE_URL=https://spesa-pronta.it

# Email transazionali opzionali: benvenuto + recupero password
# Crea una chiave su Resend o servizio equivalente e verifica il dominio/email mittente.
RESEND_API_KEY=INSERISCI_CHIAVE_RESEND
EMAIL_FROM=Spesa Pronta <noreply@spesa-pronta.it>
