# Spesa Pronta AI Backend
# Copia questo file in .env e inserisci la tua chiave.
# NON mettere mai questa chiave dentro index.html, app.js o frontend pubblico.

OPENAI_API_KEY=INSERISCI_LA_TUA_CHIAVE_OPENAI
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_MODEL_FALLBACKS=gpt-5.5,gpt-5.4-mini,gpt-5.4-nano
OPENAI_TIMEOUT_MS=60000
PORT=3000
DB_PATH=./cloud-db.json

# Database cloud Supabase/Postgres
# Incolla su Render la stringa completa preparata da Supabase.
DATABASE_URL=postgresql://postgres.xxxxx:LA_TUA_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:5432/postgres


# Sicurezza dati / cifratura lato server
# Metti una frase lunga casuale su Render. Non cambiarla dopo che ci sono utenti veri,
# altrimenti il database cifrato non si può più leggere.
APP_SECRET=INSERISCI_UN_SEGRETO_LUNGO_RANDOM
APP_BASE_URL=https://spesa-pronta.it

# Email transazionali opzionali: benvenuto + recupero password
# Crea una chiave su Resend o servizio equivalente e verifica il dominio/email mittente.
RESEND_API_KEY=INSERISCI_CHIAVE_RESEND
EMAIL_FROM=Spesa Pronta <noreply@spesa-pronta.it>

# Google Assistant / Gemini bridge: endpoint pubblico da usare in App Actions/Dialogflow/bridge
# https://spesa-pronta.it/api/google-assistant?householdId=TUO_HOUSEHOLD_ID

# V28.49 PRO Vision Judge
# Lookup multi-source Open Facts family attivo di default.
KNOWLEDGE_FEEDER_ENABLED=true
KNOWLEDGE_FEEDER_TIMEOUT_MS=3600
OPEN_FACTS_USER_AGENT=SpesaPronta/28.49 ProVisionJudge (server-learning; contact: admin@spesapronta.local)

# Console cervello a casa / motore visivo esterno opzionale.
# Se non compilati, non viene chiamato nulla e non costa nulla.
HOME_BRAIN_URL=
HOME_BRAIN_TOKEN=
VISION_EXTERNAL_MATCH_URL=
VISION_EXTERNAL_MATCH_TOKEN=
VISION_EXTERNAL_MATCH_TIMEOUT_MS=2600

# V28.49 PRO ChatGPT-Level Vision Judge
# Regola: gli ingredienti/tracce/colori non creano identita' prodotto.
# Le API visive esterne sono opzionali e DISATTIVE di default per non spendere soldi.
VISION_VISUAL_APIS_ENABLED=false
VISION_PAID_APIS_ENABLED=false
VISION_EXTERNAL_MAX_IMAGE_BYTES=900000

# Hugging Face opzionale: utile per label generiche/firma visiva, non per inventare nome prodotto.
HF_VISION_ENABLED=false
HF_API_TOKEN=
HF_VISION_MODEL=google/vit-base-patch16-224
HF_VISION_API_URL=

# Google Vision opzionale e potenzialmente a pagamento: parte solo con VISION_PAID_APIS_ENABLED=true.
GOOGLE_VISION_ENABLED=false
GOOGLE_VISION_API_KEY=

# Token proprietario per modifiche nel Cervello Server.
SERVER_BRAIN_OWNER_TOKEN=

# V28.64 PRO OCR/Pixels
# OCR.space è opzionale: con una chiave gratuita può leggere etichette lato server senza OpenAI.
OCR_SPACE_ENABLED=false
OCR_SPACE_API_KEY=
OCR_SPACE_LANGUAGE=ita
OCR_SPACE_ENGINE=2
OCR_SPACE_TIMEOUT_MS=6500

# Google Vision OCR è opzionale e potenzialmente a pagamento: resta spento finché non lo abiliti.
GOOGLE_VISION_OCR_ENABLED=false
GOOGLE_VISION_TIMEOUT_MS=5500

# V28.65 PRO OCR quality gate / crop OCR
OCR_SPACE_MAX_CROPS=2

# V28.68 PRO OCR Router / Cervello Server / Realistic Render
OCR_SPACE_MAX_CROPS=4
SERVER_BRAIN_OWNER_TOKEN=

# V31 GPU Vision Bridge / RunPod
GPU_VISION_ENABLED=true
GPU_VISION_URL=https://YOUR-POD-8000.proxy.runpod.net
GPU_VISION_TOKEN=your_private_token
GPU_VISION_TIMEOUT_MS=45000
GPU_VISION_ANALYZE_PATH=/analyze-product
GPU_VISION_RENDER_PATH=/render-product
GPU_VISION_HEALTH_PATH=/health
GPU_VISION_VERSION=32.0

# V31.4 Render RAM Safe - consigliato su Render 512MB
SPESA_MEMORY_MODE=light
SPESA_RAM_SAFE=true
DISABLE_GOOGLE_HTML_SCRAPE=1
GPU_VISION_ENABLED=false
MAX_MEMORY_CACHE=120
MAX_DIAGNOSTIC_EVENTS=50
MAX_GLOBAL_PRODUCTS=800
MAX_PRODUCT_PHOTOS=8
MAX_STORED_DATA_URL_CHARS=0
SPESA_MEMORY_LOGS=true

# V31.6: conserva anteprime leggere anche in RAM-safe (non foto enormi)
MAX_STORED_THUMB_DATA_URL_CHARS=140000
MAX_PRODUCT_PHOTOS=8

# RunPod V32 PRO endpoints
GPU_VISION_RENDER_PRO_PATH=/render-pro
GPU_VISION_LABEL_PATH=/label-pro
GPU_VISION_RENDER_3D_PATH=/render-3d
